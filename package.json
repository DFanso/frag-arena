{
  "name": "cf-fps",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy -c dist/cf_fps/wrangler.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "build:client": "vite build --config vite.config.client.ts",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --target=node22 --packages=external --outfile=dist/server/index.js",
    "build:node": "npm run build:client && npm run build:server",
    "start": "node dist/server/index.js",
    "dev:node": "tsx watch server/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.0",
    "three": "^0.184.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/vitest-pool-workers": "^0.13.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/node": "^22.10.2",
    "@types/three": "^0.184.0",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.20.0"
  }
}
